FLASK_ENV=development
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here

# MySQL
DEV_DATABASE_URL=mysql+pymysql://root:password@localhost:3306/attendance_dev?charset=utf8mb4
TEST_DATABASE_URL=mysql+pymysql://root:password@localhost:3306/attendance_test?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/attendance_prod?charset=utf8mb4

# AI 配置
MODEL_TYPE=resnet50
DEVICE=cpu
SIM_THRESHOLD_HIGH=0.75
SIM_THRESHOLD_LOW=0.50

# 业务参数
FACE_MIN_COUNT=5
ABSENCE_TRIGGER_COUNT=3
TRAIN_TRIGGER_BATCH=10
